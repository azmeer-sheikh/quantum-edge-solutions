# Canonical site URL (no trailing slash). Used for canonical tags, sitemap, and JSON-LD.
VITE_SITE_URL=https://quantumedgesolution.org

# Default Open Graph / Twitter image (absolute URL). Falls back to VITE_SITE_URL/og-default.png.
# VITE_OG_IMAGE=https://quantumedgesolution.org/og-default.png

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
# VITE_GA_MEASUREMENT_ID=

# Google Search Console HTML tag verification content
# VITE_GSC_VERIFICATION=
